---
import Layout from '../layouts/Layout.astro';

/* ============================================================
 * 数据层（Data Layer）：insightsData 数组
 * 逻辑：每条 Insight 包含 id、标题、评论正文、原文链接、标签（Tags）。
 * 后续可通过 API 将阅读时的评论自动推送至此数组（模拟自动化 Automated Simulation）。
 * 术语：Cognitive Map（认知地图）——用图结构可视化思想与知识之间的关联。
 * ============================================================ */
interface InsightItem {
	id: string;
	title: string;
	comment: string;
	articleLink: string;
	articleTitle?: string;
	tags: string[];
}

const insightsData: InsightItem[] = [
	{
		id: "insight-1",
		title: "What happened to cognitive science?",
		comment: "Cognitive Science has not much inprovement in the field, instaed, its goes more towards cognitive psychology field",
		articleLink: "https://www.nature.com/articles/s41562-019-0626-2",
		articleTitle: "What happened to cognitive science?",
		tags: ["Human behaviour", "Cognitive Science"],
	},
	{
		id: "insight-2",
		title: "Working Memory vs. Long-Term Memory",
		comment:
			"Working memory is characterized as a limited, fragile, and currently active state of thought. In contrast, long-term memory is an enormous and stable repository of knowledge. The serial position curve demonstrates these differences through the primacy effect, linked to LTM transfer via rehearsal, and the recency effect, which stems from items remaining in working memory.",
		articleLink: "Local PDF: Week 6 Reading Chapter 6",
		articleTitle: "The Acquisition of Memories and the Working-Memory System",
		tags: ["Cognitive Science", "LTM", "Serial Position Effect", "Chunking"],
	},
	{
		id: "insight-3",
		title: "Retrieval Paths and the Nature of Recognition",
		comment:
			"Memory retrieval is facilitated by spreading activation across a network of interconnected nodes. Semantic priming occurs when the activation of one node partially activates related nodes, speeding up subsequent recognition. Recognition can be based on source memory, which requires specific hippocampal activity, or a general sense of familiarity linked to the rhinal cortex.",
		articleLink: "Local PDF: Week 8 Reading Chapter 7",
		articleTitle: "Interconnections between Acquisition and Retrieval",
		tags: ["Cognitive Science", "Semantic Priming", "Recognition", "Source Memory"],
	},
	{
		id: "insight-4",
		title: "Memory Errors and Intrusion Effects",
		comment:
			"Memory is stored in a vast, interconnected network where boundaries between episodes are not always distinct[cite: 480, 482]. This density of connections can lead to transplant errors, where elements from one context are misremembered as belonging to another[cite: 498]. Intrusion errors occur when prior expectations or general knowledge (schemas) override the reality of a specific experience[cite: 456, 505].",
		articleLink: "Local PDF: Week 9 Reading Chapter 8",
		articleTitle: "Remembering Complex Events",
		tags: ["Memory Errors", "Cognitive Science", "False Memories", "Network Model"],
	},
	{
		id: "insight-5",
		title: "The Hierarchical Organization of Language",
		comment:
			"Language is organized into a hierarchy starting from phonemes (smallest sound units) to morphemes (smallest meaning units), words, phrases, and sentences[cite: 527, 558, 559, 563]. Disorders like aphasia highlight that brain areas for language comprehension and production are distinct[cite: 512, 518]. Despite strict rules of syntax, language remains generative, allowing for an unlimited creation of new forms[cite: 530].",
		articleLink: "Local PDF: Week 10 Reading Chapter 10",
		articleTitle: "Language Organization and Aphasia",
		tags: ["Linguistics", "Morphemes", "Phonemes", "Aphasia", "Generativity"],
	},
	{
		id: "insight-6",
		title: "The Transformer Revolution",
		comment:
			"This foundational paper introduced the Transformer architecture, which eschews recurrence and convolutions in favor of self-attention mechanisms. By utilizing multi-head attention to draw global dependencies, the model enables significantly higher parallelization and reduced training times. The core innovation is the Scaled Dot-Product Attention formula: $$Attention(Q, K, V) = \\text{softmax}\\left(\\frac{QK^T}{\\sqrt{d_k}}\\right)V$$. This architecture serves as the backbone for nearly all modern large language models, including GPT and BERT.",
		articleLink:
			"https://proceedings.neurips.cc/paper_files/paper/2017/file/3f5ee243547dee91fbd053c1c4a845aa-Paper.pdf",
		articleTitle: "Attention Is All You Need",
		tags: ["Transformer", "Self-Attention", "Deep Learning", "Parallelization"],
	},
	{
		id: "insight-7",
		title: "Strategic Influence in Social Deduction Games",
		comment:
			"This paper analyzes how LLM agents can be trained for persuasive communication in games like Werewolf (Mafia). It treats dialogue as a Stackelberg competition where players strategically influence others' beliefs, a key concept for your interests in Distributed Cognition.",
		articleLink:
			"https://www.researchgate.net/publication/396458910_Leading_the_Follower_Learning_Persuasive_Agents_in_Social_Deduction_Games",
		articleTitle: "Leading the Follower: Learning Persuasive Agents in Social Deduction Games",
		tags: ["Distributed Cognition", "LLM Agents", "Game Theory", "Social Deduction"],
	},
	{
		id: "insight-8",
		title: "The Extended Mind Thesis",
		comment:
			"The foundational argument that cognition is not limited to the biological brain but is 'coupled' with external tools and environmental artifacts. You've discussed this in the context of how the internet and personal knowledge management tools act as cognitive scaffolds.",
		articleLink: "https://direct.mit.edu/books/edited-volume/2362/The-Extended-Mind",
		articleTitle: "The Extended Mind",
		tags: ["Philosophy of Mind", "Extended Mind", "Andy Clark", "Scaffolding"],
	},
	{
		id: "insight-9",
		title: "Distributed Cognition and Cultural Practices",
		comment:
			"Hutchins argues that human intelligence emerges from distributed systems that transcend individual boundaries. You specifically examined his reinterpretation of primate tasks to show how cultural practices orchestrate cognitive outcomes.",
		articleLink:
			"https://classes.matthewjbrown.net/teaching-files/cognitive-ethnography/hutchins-emergence-human.pdf",
		articleTitle: "The role of cultural practices in the emergence of modern human intelligence",
		tags: ["Distributed Cognition", "Cognitive Ethnography", "Edwin Hutchins", "Evolution"],
	},
	{
		id: "insight-10",
		title: "Sociocultural Theory and the ZPD",
		comment:
			"Vygotsky's framework focusing on how social interaction and 'More Knowledgeable Others' (MKOs) drive development. You've looked into how the Zone of Proximal Development applies to human learning and AI-assisted education.",
		articleLink: "https://www.simplypsychology.org/vygotsky.html",
		articleTitle: "Vygotsky's Sociocultural Theory of Cognitive Development",
		tags: ["Developmental Psychology", "ZPD", "Social Learning", "Evolution"],
	},
];

/* ============================================================
 * 数据层：Questions 数组（用于「Questions in my head...」交互区）
 * 逻辑：每条含 id、问题正文、模拟的「他人回答」列表；后续可接 API 真实留言。
 * 示例主题：Human-AI Interaction（人机交互）、认知景观、技术与社会摩擦。
 * ============================================================ */
interface QuestionItem {
	id: string;
	text: string;
	answers: string[]; /* 他人回答（Unlock 后展示） */
}

const questionsData: QuestionItem[] = [
	{
		id: "q1",
		text: "Not all friction is a flaw. How do we clear the barriers to learning while preserving the struggle that's essential for our thought?",
		answers: ["可以约定：AI 只给选项与依据，最终决策必须由人做出并记录理由。", "我认为关键在「可解释性」——知道 AI 为何这样建议，才能判断是否采纳。"],
	},
	{
		id: "q2",
		text: "As the cognitive landscape is constantly reshaped by algorithms, how do we distinguish between "what we truly want" and "the preferences cultivated by the recommendation system"?",
		answers: ["定期做「信息斋戒」：一段时间不用推荐流，观察自己会主动找什么。", "可以保留一块「非算法」的信息入口，比如固定订阅的 newsletter、朋友推荐。"],
	},
	{
		id: "q3",
		text: "As automation replaces a large number of intermediate steps, what touchpoints do we lose besides jobs?",
		answers: ["隐性知识往往在「做」的过程中传递，自动化若完全跳过人工环节，这些经验就难以传承。", "接触点减少也会影响信任建立——以前通过人工客服、线下窗口建立的信任，需要新的设计来替代。"],
	},
	{
		id: "q4",
		text: "How do humans navigate a world where AI is designed to echo our own biases back to us?",
		answers: ["让 AI 明确标出置信度与不确定性，避免「看起来非常确定」的错觉。", "提供「撤销 / 回退」与「人工复核」的出口，让用户感到始终有兜底。"],
	},
];
---

<Layout title="Insights - My Portfolio">

	<!-- ============================================================
	     视觉：纯白背景、单色极简，与主页一致（Visual Style）。
	     主区域为力导向图容器，右侧为可滑出的侧边栏（Sidebar）。
	     ============================================================ -->
	<div class="insights-page">
		<header class="insights-header">
			<h1 class="insights-title">Insights</h1>
			<p class="insights-subtitle">Cognitive Map – Click on a node to view details and my comments!</p>
		</header>

		<!-- 力导向图（Force-Directed Graph）容器：占满剩余空间，支持缩放与拖拽 -->
		<div class="graph-wrap">
			<div id="graph-container" class="graph-container" data-insights={JSON.stringify(insightsData)}></div>
		</div>

		<!-- ============================================================
		     侧边栏（Sidebar）：点击节点时滑出，展示该条 Insight 的评论与原文链接。
		     逻辑：默认 translateX(100%) 隐藏；添加 .open 时 translateX(0) 滑入。
		     ============================================================ -->
		<aside id="insights-sidebar" class="sidebar" aria-hidden="true">
			<div class="sidebar-inner">
				<button type="button" class="sidebar-close" id="sidebar-close" aria-label="关闭侧边栏">×</button>
				<h2 id="sidebar-title" class="sidebar-title"></h2>
				<p id="sidebar-comment" class="sidebar-comment"></p>
				<a id="sidebar-link" class="sidebar-link" href="#" target="_blank" rel="noopener noreferrer"></a>
			</div>
		</aside>

		<!-- 侧边栏遮罩层（Sidebar Backdrop）：用于点击空白处关闭侧边栏 / 底部抽屉（Bottom Sheet） -->
		<div id="insights-sidebar-backdrop" class="sidebar-backdrop" aria-hidden="true"></div>

		<!-- ============================================================
		     「Questions in my head...」交互区（页面底部）
		     视觉：大标题（text-black text-3xl font-bold mb-8）+ 瀑布流（Masonry Layout）问题卡片；白底、极细灰边，单色调（Monochromatic）。
		     交互：点击问题 → 打开模态框（Modal）；左侧问题、右侧留言板（textarea）；提交前「他人回答」模糊（Blur），提交后解锁（Unlock）并展示。
		     术语：Masonry Layout（瀑布流）、Modal（模态框）、Blur（模糊）、Unlock（解锁机制）。
		     ============================================================ -->
		<section class="questions-section">
			<h2 class="questions-heading">Questions in my head...</h2>
			<div class="questions-masonry">
				{questionsData.map((q) => (
					<button
						type="button"
						class="question-card"
						data-question-id={q.id}
						data-question-text={q.text}
						data-question-answers={JSON.stringify(q.answers)}
					>
						{q.text}
					</button>
				))}
			</div>
		</section>

		<!-- 模态框（Modal）：点击问题后弹出，左侧问题、右侧留言板；提交后解锁「他人回答」 -->
		<div id="questions-modal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-question-title" aria-hidden="true">
			<div class="modal-backdrop" id="modal-backdrop"></div>
			<div class="modal-dialog">
				<button type="button" class="modal-close" id="modal-close" aria-label="关闭">×</button>
				<h3 id="modal-question-title" class="modal-question-title"></h3>
				<div class="modal-body">
					<div class="modal-left">
						<p id="modal-question-text" class="modal-question-text"></p>
					</div>
					<div class="modal-right">
						<!-- 表单区域（Form）：昵称 + 留言输入（textarea），提交后隐藏，用于真实评论交互（Real Comment Interaction） -->
						<div id="modal-form" class="modal-form">
							<label for="modal-nickname" class="modal-label">Your Nickname (Optional)</label>
							<input
								id="modal-nickname"
								class="modal-input"
								type="text"
								placeholder="Your Nickname (Optional)"
							/>
							<label for="modal-textarea" class="modal-label">留下你的想法</label>
							<textarea id="modal-textarea" class="modal-textarea" placeholder="写几句你的看法或回答..." rows={5}></textarea>
							<button type="button" class="modal-submit" id="modal-submit">提交</button>
						</div>

						<!-- 提交成功反馈（Success Feedback）：显示“Thank you!”提示 -->
						<div id="modal-success" class="modal-success">
							<p>Thank you for sharing your thoughts!</p>
						</div>
					</div>
				</div>
				<div id="modal-answers-wrap" class="modal-answers-wrap">
					<h4 class="modal-answers-title">他人回答</h4>
					<ul id="modal-answers-list" class="modal-answers-list"></ul>
				</div>
			</div>
		</div>
	</div>

	<style>
		/* ============================================================
		 * 页面容器：纯白背景、全高，与主页单色极简风格一致（Monochromatic）。
		 * ============================================================ */
		.insights-page {
			position: relative;
			min-height: calc(100vh - 60px);
			background: #ffffff;
			padding: 1.5rem 1rem 2rem;
		}

		.insights-header {
			max-width: 1200px;
			margin: 0 auto 1.5rem;
		}

		.insights-title {
			font-size: 2rem;
			font-weight: 700;
			color: #000000;
			margin: 0 0 0.35rem;
		}

		.insights-subtitle {
			font-size: 0.95rem;
			color: #374151;
			margin: 0;
		}

		/* 图容器：占满可视区域，用于挂载 SVG（D3 将在此绘制节点与边） */
		.graph-wrap {
			position: relative;
			width: 100%;
			height: calc(100vh - 180px);
			min-height: 400px;
			max-width: 1200px;
			margin: 0 auto;
			border: 1px solid #e5e7eb;
			border-radius: 0.5rem;
			overflow: hidden;
			background: #ffffff;
		}

		.graph-container {
			width: 100%;
			height: 100%;
		}

		/* 选中节点 Active State：描边加粗 + 轻微发光（单色黑灰系），提升视觉显著性（Visual Saliency） */
		.nodes g.active-node circle {
			fill: #000000;
			stroke: #000000;
			stroke-width: 2;
			filter: drop-shadow(0 0 6px rgba(0, 0, 0, 0.25));
		}

		/* 侧边栏（Sidebar）：移动端为 Bottom Sheet，桌面端为右侧滑出 Panel */		
		.sidebar {
			position: fixed;
			left: 0;
			right: 0;
			bottom: 0;
			top: auto;
			width: 100%;
			max-width: 100%;
			max-height: 75vh;
			background: #ffffff;
			border-top: 1px solid #e5e7eb;
			box-shadow: 0 -6px 24px rgba(0, 0, 0, 0.08);
			z-index: 120;
			transform: translateY(100%);
			transition: transform 0.3s ease;
			overflow-y: auto;
			/* backdrop-blur：让底部浮层更通透（Backdrop Blur） */
			backdrop-filter: blur(16px);
			-webkit-backdrop-filter: blur(16px);
		}

		.sidebar.open {
			transform: translateY(0);
		}

		/* 桌面端（Desktop）：改为右侧滑出 Panel，覆盖 Bottom Sheet 布局设置 */
		@media (min-width: 768px) {
			.sidebar {
				top: 0;
				right: 0;
				bottom: 0;
				left: auto;
				width: 100%;
				max-width: 380px;
				height: 100vh;
				max-height: none;
				border-top: none;
				border-left: 1px solid #e5e7eb;
				box-shadow: -4px 0 24px rgba(0, 0, 0, 0.06);
				transform: translateX(100%);
			}

			.sidebar.open {
				transform: translateX(0);
			}
		}

		/* 侧边栏遮罩（Backdrop）：点击空白处关闭 Side Panel / Bottom Sheet */
		.sidebar-backdrop {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.25);
			z-index: 110;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.3s ease;
		}

		.sidebar-backdrop.open {
			opacity: 1;
			pointer-events: auto;
		}

		.sidebar-inner {
			padding: 2rem 1.5rem;
		}

		.sidebar-close {
			position: absolute;
			top: 1rem;
			right: 1rem;
			width: 2rem;
			height: 2rem;
			border: none;
			background: transparent;
			font-size: 1.5rem;
			line-height: 1;
			color: #374151;
			cursor: pointer;
			border-radius: 0.25rem;
			transition: background 0.2s, color 0.2s;
		}

		.sidebar-close:hover {
			background: #f3f4f6;
			color: #000000;
		}

		.sidebar-title {
			font-size: 1.25rem;
			font-weight: 700;
			color: #000000;
			margin: 0 0 1rem;
			padding-right: 2rem;
		}

		.sidebar-comment {
			font-size: 0.95rem;
			color: #374151;
			line-height: 1.65;
			margin: 0 0 1.25rem;
		}

		.sidebar-link {
			display: inline-block;
			font-size: 0.9rem;
			font-weight: 500;
			color: #1d4ed8;
			text-decoration: none;
			border-bottom: 1px solid #1d4ed8;
			transition: color 0.2s, border-color 0.2s;
		}

		.sidebar-link:hover {
			color: #1e40af;
			border-color: #1e40af;
		}

		/* ============================================================
		 * 「Questions in my head...」区域
		 * 视觉：标题大号加粗黑体（text-black text-3xl font-bold mb-8）；纯白背景，单色调（Monochromatic）。
		 * ============================================================ */
		.questions-section {
			max-width: 1200px;
			margin: 0 auto;
			padding: 4rem 0 3rem;
		}

		.questions-heading {
			font-size: 1.875rem; /* text-3xl */
			font-weight: 700;
			color: #000000;
			margin: 0 0 2rem;
		}

		/* 瀑布流布局（Masonry Layout）：多列等高错落，无需固定高度 */
		.questions-masonry {
			column-count: 1;
			column-gap: 1rem;
		}

		@media (min-width: 640px) {
			.questions-masonry {
				column-count: 2;
			}
		}

		@media (min-width: 1024px) {
			.questions-masonry {
				column-count: 3;
			}
		}

		/* 问题卡片：白底、极细灰边（border-gray-100）、圆角，可点击 */
		.question-card {
			display: block;
			width: 100%;
			margin-bottom: 1rem;
			padding: 1.25rem;
			background: #ffffff;
			border: 1px solid #f3f4f6;
			border-radius: 0.5rem;
			text-align: left;
			font-size: 0.95rem;
			line-height: 1.55;
			color: #111827;
			cursor: pointer;
			transition: border-color 0.2s, box-shadow 0.2s;
			break-inside: avoid;
			font-family: inherit;
		}

		.question-card:hover {
			border-color: #e5e7eb;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
		}

		/* ============================================================
		 * 模态框（Modal）：遮罩 + 对话框，点击问题打开，左侧问题、右侧 textarea 留言板。
		 * ============================================================ */
		.modal {
			position: fixed;
			inset: 0;
			z-index: 200;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 1rem;
			opacity: 0;
			visibility: hidden;
			transition: opacity 0.25s ease, visibility 0.25s ease;
		}

		.modal.open {
			opacity: 1;
			visibility: visible;
		}

		.modal-backdrop {
			position: absolute;
			inset: 0;
			background: rgba(0, 0, 0, 0.4);
		}

		.modal-dialog {
			position: relative;
			width: 100%;
			max-width: 640px;
			max-height: 90vh;
			overflow-y: auto;
			background: #ffffff;
			border: 1px solid #e5e7eb;
			border-radius: 0.5rem;
			box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
			padding: 1.75rem;
		}

		.modal-close {
			position: absolute;
			top: 1rem;
			right: 1rem;
			width: 2rem;
			height: 2rem;
			border: none;
			background: transparent;
			font-size: 1.5rem;
			line-height: 1;
			color: #374151;
			cursor: pointer;
			border-radius: 0.25rem;
			transition: background 0.2s, color 0.2s;
		}

		.modal-close:hover {
			background: #f3f4f6;
			color: #000000;
		}

		.modal-question-title {
			font-size: 1rem;
			font-weight: 600;
			color: #374151;
			margin: 0 2rem 0 0;
		}

		.modal-body {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
			margin-top: 1rem;
		}

		@media (max-width: 600px) {
			.modal-body {
				grid-template-columns: 1fr;
			}
		}

		.modal-question-text {
			font-size: 0.95rem;
			color: #111827;
			line-height: 1.6;
			margin: 0;
		}

		.modal-right {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}

		/* 昵称输入框（Nickname Input）：简洁单行 input，保持单色极简风格 */		
		.modal-input {
			width: 100%;
			padding: 0.5rem 0.75rem;
			border: 1px solid #e5e7eb;
			border-radius: 0.375rem;
			font-size: 0.9rem;
			font-family: inherit;
		}

		.modal-input:focus {
			outline: none;
			border-color: #111827;
		}

		.modal-label {
			font-size: 0.875rem;
			font-weight: 500;
			color: #374151;
		}

		.modal-textarea {
			width: 100%;
			padding: 0.75rem;
			border: 1px solid #e5e7eb;
			border-radius: 0.375rem;
			font-size: 0.9rem;
			font-family: inherit;
			resize: vertical;
			min-height: 100px;
		}

		.modal-textarea:focus {
			outline: none;
			border-color: #111827;
		}

		.modal-submit {
			align-self: flex-start;
			padding: 0.5rem 1.25rem;
			background: #111827;
			color: #ffffff;
			border: none;
			border-radius: 0.375rem;
			font-size: 0.875rem;
			font-weight: 500;
			cursor: pointer;
			transition: background 0.2s;
		}

		.modal-submit:hover {
			background: #374151;
		}

		/* 表单容器（Form Container）和成功反馈（Success Feedback）切换显示 */		
		.modal-form.hidden {
			display: none;
		}

		.modal-success {
			opacity: 0;
			visibility: hidden;
			transform: translateY(8px);
			margin-top: 0.5rem;
			font-size: 0.95rem;
			font-weight: 500;
			color: #111827;
			transition: opacity 0.5s ease, transform 0.5s ease, visibility 0.5s;
			position: absolute;
		}

		.modal-success.visible {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
			position: relative;
		}

		/* 他人回答区域：未提交前模糊（Blur），提交后解锁（Unlock）并淡入 */
		.modal-answers-wrap {
			margin-top: 1.5rem;
			padding-top: 1.5rem;
			border-top: 1px solid #f3f4f6;
			filter: blur(8px);
			opacity: 0.4;
			pointer-events: none;
			transition: filter 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease;
		}

		.modal-answers-wrap.unlocked {
			filter: blur(0);
			opacity: 1;
			pointer-events: auto;
		}

		.modal-answers-title {
			font-size: 0.875rem;
			font-weight: 600;
			color: #374151;
			margin: 0 0 0.75rem;
		}

		.modal-answers-list {
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.modal-answers-list li {
			padding: 0.6rem 0;
			font-size: 0.9rem;
			color: #1f2937;
			line-height: 1.5;
			border-bottom: 1px solid #f3f4f6;
		}

		.modal-answers-list li:last-child {
			border-bottom: none;
		}
	</style>

	<!--
		术语（Terminology）：
		- Force-Directed Graph（力导向图）：节点与边在物理模拟下自动排布，有关联的节点会靠近。
		- Zoom（缩放）/ Drag（拖拽）：HCI 优化，便于用户探索大型图。
		- Sidebar（侧边栏）：从侧边滑出的面板，用于展示详情而不离开当前页。
	-->

	<script>
		import * as d3 from 'd3';
		import { supabase } from '../lib/supabaseClient';

		/* 1. Initialize: D3 + Supabase client; expose on window for any external use */
		if (typeof window !== 'undefined') {
			// @ts-ignore
			window.supabase = supabase;
		}

		/* ============================================================
		 * 根据 Tags 构建边（Links）：若两条 Insight 拥有至少一个相同标签，则连一条边。
		 * ============================================================ */
		function buildLinks(nodes: { id: string; tags: string[] }[]) {
			const links: { source: string; target: string }[] = [];
			for (let i = 0; i < nodes.length; i++) {
				for (let j = i + 1; j < nodes.length; j++) {
					const a = nodes[i].tags;
					const b = nodes[j].tags;
					if (a.some((t: string) => b.includes(t))) {
						links.push({ source: nodes[i].id, target: nodes[j].id });
					}
				}
			}
			return links;
		}

		/* ============================================================
		 * 初始化力导向图（Force-Directed Graph）
		 * ============================================================ */
		const container = document.getElementById('graph-container');
		if (!container) throw new Error('graph-container not found');

		const rawData = container.getAttribute('data-insights');
		const insightsData: { id: string; title: string; comment: string; articleLink: string; articleTitle?: string; tags: string[] }[] = rawData ? JSON.parse(rawData) : [];

		const width = container.clientWidth;
		const height = container.clientHeight;

		const sidebarBackdrop = document.getElementById('insights-sidebar-backdrop');

		const nodes = insightsData.map((d) => ({
			...d,
			// D3 力模拟会为节点附加 x, y，此处可省略，由 simulation 初始化
		}));

		const links = buildLinks(nodes);

		/* 力模拟（Force Simulation） */
		const simulation = d3
			.forceSimulation(nodes)
			.force('link', d3.forceLink(links).id((d: { id: string }) => d.id).distance(120))
			.force('charge', d3.forceManyBody().strength(-280))
			.force('center', d3.forceCenter(width / 2, height / 2));

		/* SVG：挂载到 graph-container，用于缩放（Zoom）的 g 包裹所有图元 */
		const svg = d3
			.select(container)
			.append('svg')
			.attr('width', width)
			.attr('height', height)
			.attr('viewBox', [0, 0, width, height]);

		/* 缩放（Zoom）行为：鼠标滚轮缩放，拖拽画布平移，提升探索体验（HCI Optimization） */
		const g = svg.append('g');
		svg.call(
			d3
				.zoom()
				.scaleExtent([0.2, 4])
				.on('zoom', (event) => g.attr('transform', event.transform))
		);

		/* 边（Links）：线条，黑色/深灰，无箭头 */
		const link = g
			.append('g')
			.attr('class', 'links')
			.selectAll('line')
			.data(links)
			.join('line')
			.attr('stroke', '#9ca3af')
			.attr('stroke-opacity', 0.6)
			.attr('stroke-width', 1);

		/* 节点组（Nodes）：每个节点一个 g，内含圆 + 文字 */
		const node = g
			.append('g')
			.attr('class', 'nodes')
			.selectAll('g')
			.data(nodes)
			.join('g')
			.attr('cursor', 'pointer')
			.call(
				d3
					.drag()
					.on('start', (event, d: { fx?: number; fy?: number }) => {
						if (!event.active) simulation.alphaTarget(0.3).restart();
						d.fx = d.x;
						d.fy = d.y;
					})
					.on('drag', (event, d: { fx?: number; fy?: number }) => {
						d.fx = event.x;
						d.fy = event.y;
					})
					.on('end', (event, d: { fx?: number; fy?: number }) => {
						if (!event.active) simulation.alphaTarget(0);
						d.fx = null;
						d.fy = null;
					})
			)
			.on('click', (event, d: (typeof insightsData)[0]) => {
				/* 点击节点：打开侧边栏并填充该条 Insight 的详情（Data Interaction） */
				const sidebar = document.getElementById('insights-sidebar');
				const titleEl = document.getElementById('sidebar-title');
				const commentEl = document.getElementById('sidebar-comment');
				const linkEl = document.getElementById('sidebar-link') as HTMLAnchorElement;
				if (sidebar && titleEl && commentEl && linkEl) {
					/* 先清除所有节点的激活态（Active State），再为当前节点添加 active-node 类 */
					node.classed('active-node', false);
					d3.select(event.currentTarget as SVGGElement).classed('active-node', true);

					titleEl.textContent = d.title;
					commentEl.textContent = d.comment;
					linkEl.href = d.articleLink;
					linkEl.textContent = d.articleTitle || '阅读原文';
					sidebar.classList.add('open');
					sidebar.setAttribute('aria-hidden', 'false');
					sidebarBackdrop?.classList.add('open');
					sidebarBackdrop?.setAttribute('aria-hidden', 'false');
				}
			});

		node.append('circle').attr('r', 10).attr('fill', '#111827').attr('stroke', '#374151').attr('stroke-width', 1);

		node
			.append('text')
			.text((d: { title: string }) => d.title)
			.attr('font-size', 11)
			.attr('fill', '#111827')
			.attr('dx', 14)
			.attr('dy', 4)
			.style('pointer-events', 'none');

		/* 每帧将模拟得到的坐标同步到 DOM（tick 事件） */
		simulation.on('tick', () => {
			link
				.attr('x1', (d: { source: { x: number } }) => d.source.x)
				.attr('y1', (d: { source: { y: number } }) => d.source.y)
				.attr('x2', (d: { target: { x: number } }) => d.target.x)
				.attr('y2', (d: { target: { y: number } }) => d.target.y);
			node.attr('transform', (d: { x: number; y: number }) => `translate(${d.x},${d.y})`);
		});

		/* 侧边栏关闭函数：隐藏 Panel / Bottom Sheet，并移除所有节点的激活态（Active State） */
		function closeSidebar() {
			const sidebar = document.getElementById('insights-sidebar');
			if (sidebar) {
				sidebar.classList.remove('open');
				sidebar.setAttribute('aria-hidden', 'true');
			}
			sidebarBackdrop?.classList.remove('open');
			sidebarBackdrop?.setAttribute('aria-hidden', 'true');
			node.classed('active-node', false);
		}

		/* 侧边栏关闭按钮 + 点击遮罩关闭（点击背景空白处） */
		document.getElementById('sidebar-close')?.addEventListener('click', closeSidebar);
		sidebarBackdrop?.addEventListener('click', closeSidebar);

		/* ============================================================
		 * 3. Questions 区域：真实评论交互（Real Comment Interaction）
		 * 逻辑：allAnswers 缓存；Supabase 查询/插入；提交后解锁「他人回答」。
		 * ============================================================ */
		const modal = document.getElementById('questions-modal');
		const modalBackdrop = document.getElementById('modal-backdrop');
		const modalClose = document.getElementById('modal-close');
		const modalQuestionTitle = document.getElementById('modal-question-title');
		const modalQuestionText = document.getElementById('modal-question-text');
		const modalNickname = document.getElementById('modal-nickname');
		const modalTextarea = document.getElementById('modal-textarea');
		const modalSubmit = document.getElementById('modal-submit');
		const modalForm = document.getElementById('modal-form');
		const modalSuccess = document.getElementById('modal-success');
		const modalAnswersWrap = document.getElementById('modal-answers-wrap');
		const modalAnswersList = document.getElementById('modal-answers-list');

		const allAnswers: { questionId: string; nickname: string; content: string; createdAt: string }[] = [];
		let currentQuestionId: string | null = null;

		async function loadInitialAnswers() {
			try {
				const { data, error } = await supabase
					.from('comments')
					.select('*')
					.order('created_at', { ascending: true });
				if (error) {
					console.error('加载评论失败（load comments error）', error);
					return;
				}
				if (Array.isArray(data)) {
					data.forEach((row: { question_id: string; nickname?: string; content: string; created_at?: string }) => {
						allAnswers.push({
							questionId: row.question_id,
							nickname: row.nickname || 'Anonymous',
							content: row.content,
							createdAt: row.created_at
								? new Date(row.created_at).toLocaleString()
								: new Date().toLocaleString(),
						});
					});
				}
			} catch (err) {
				console.error('加载评论异常（load comments exception）', err);
			}
		}

		function renderAnswers(questionId: string) {
			if (!modalAnswersList) return;
			modalAnswersList.innerHTML = '';
			const related = allAnswers.filter((a) => a.questionId === questionId);
			related.forEach((a) => {
				const li = document.createElement('li');
				const header = document.createElement('div');
				header.style.display = 'flex';
				header.style.justifyContent = 'space-between';
				header.style.fontSize = '0.8rem';
				header.style.color = '#6b7280';
				const nick = document.createElement('span');
				nick.textContent = a.nickname || 'Anonymous';
				const time = document.createElement('span');
				time.textContent = a.createdAt;
				header.appendChild(nick);
				header.appendChild(time);
				const body = document.createElement('p');
				body.textContent = a.content;
				body.style.margin = '0.25rem 0 0';
				li.appendChild(header);
				li.appendChild(body);
				modalAnswersList.appendChild(li);
			});
		}

		function openModal(questionId: string, questionText: string) {
			if (!modal || !modalQuestionTitle || !modalQuestionText || !modalAnswersWrap) return;
			currentQuestionId = questionId;
			modalQuestionTitle.textContent = '问题';
			modalQuestionText.textContent = questionText;
			if (modalForm) modalForm.classList.remove('hidden');
			if (modalSuccess) modalSuccess.classList.remove('visible');
			if (modalNickname) modalNickname.value = '';
			if (modalTextarea) modalTextarea.value = '';
			if (modalAnswersWrap) modalAnswersWrap.classList.remove('unlocked');
			if (currentQuestionId) renderAnswers(currentQuestionId);
			modal.classList.add('open');
			modal.setAttribute('aria-hidden', 'false');
		}

		function closeModal() {
			if (!modal) return;
			modal.classList.remove('open');
			modal.setAttribute('aria-hidden', 'true');
		}

		/* Event delegation: single listener on container; works regardless of script/DOM timing */
		const questionsMasonry = document.querySelector('.questions-masonry');
		if (questionsMasonry) {
			questionsMasonry.addEventListener('click', (event: Event) => {
				const card = (event.target as Element).closest('.question-card');
				if (!card) return;
				const id = card.getAttribute('data-question-id') || '';
				const text = card.getAttribute('data-question-text') || '';
				console.log('Question clicked:', id);
				openModal(id, text);
			});
		}

		if (modalBackdrop) modalBackdrop.addEventListener('click', closeModal);
		if (modalClose) modalClose.addEventListener('click', closeModal);

		if (modalSubmit) {
			modalSubmit.addEventListener('click', async () => {
				if (!currentQuestionId || !modalAnswersWrap) return;
				const nicknameRaw =
					modalNickname && modalNickname.value ? modalNickname.value.trim() : '';
				const contentRaw =
					modalTextarea && modalTextarea.value ? modalTextarea.value.trim() : '';
				if (!contentRaw) return;

				const nickname = nicknameRaw || 'Anonymous';
				const createdAt = new Date();

				const originalText = modalSubmit.textContent;
				modalSubmit.textContent = 'Sending...';
				modalSubmit.setAttribute('disabled', 'true');

				try {
					const { error } = await supabase.from('comments').insert({
						question_id: currentQuestionId,
						nickname,
						content: contentRaw,
					});
					if (error) {
						console.error('提交评论失败（insert comment error）', error);
						return;
					}
					allAnswers.push({
						questionId: currentQuestionId,
						nickname,
						content: contentRaw,
						createdAt: createdAt.toLocaleString(),
					});
					renderAnswers(currentQuestionId);
					modalAnswersWrap.classList.add('unlocked');
					if (modalForm) modalForm.classList.add('hidden');
					if (modalSuccess) modalSuccess.classList.add('visible');
				} catch (err) {
					console.error('提交评论异常（insert comment exception）', err);
				} finally {
					modalSubmit.textContent = originalText || '提交';
					modalSubmit.removeAttribute('disabled');
				}
			});
		}

		/* 4. Load comments once at the end (single module, predictable order) */
		loadInitialAnswers();
	</script>

</Layout>
