---
/* 引入全站母版，首页使用 Layout 包裹以复用导航和基础样式。 */
import Layout from '../layouts/Layout.astro';

/* 视觉：首页大标题拆为「名 + 姓」两行显示。
 * 逻辑：变量在模板中通过 {firstName} {lastName} 插值渲染。 */
const firstName = "Chloe";
const lastName = "Guan";
---

<Layout title="My Portfolio">
	<!-- 视觉：首页主区块，占满整个屏幕高度，所有内容垂直水平居中。
	     逻辑：min-height:100vh 确保至少占满视口；overflow:hidden 防止旋转动画溢出产生滚动条。 -->
	<section class="hero">

		<!-- 视觉：姓名与头像横向排列——First Name 在左、头像居中、Last Name 在右。
		     逻辑：flex-row 将三个元素排成一行；gap 控制间距；items-center 使它们垂直对齐。 -->
		<div class="hero-row">
			<h1 class="hero-name">{firstName}</h1>

			<!-- 视觉：头像容器，内有两层：圆形头像（静止）+ 双弧静态文字。
			     逻辑：两层 absolute 叠放，avatar-svg 在下、avatar-arc 在上（z-index:20）。 -->
			<div class="avatar-container">
				<!-- 视觉：圆形裁剪的头像图片，居中显示。
				     逻辑：clipPath（裁剪路径）定义可见区域；viewBox 建立 SVG 坐标系 (0,0)-(200,200)。 -->
				<div class="avatar-svg">
					<svg viewBox="0 0 200 200">
						<defs>
							<clipPath id="avatarClip">
								<!-- 圆心 (100,100)、半径 50，在 200x200 画布中精确居中。 -->
								<circle cx="100" cy="100" r="50" />
							</clipPath>
						</defs>
						<!-- preserveAspectRatio="xMidYMid meet"：按比例缩放且居中对齐；clip-path 引用上方裁剪路径。 -->
						<image href="/my-avatar.PNG" x="50" y="50" width="100" height="100" preserveAspectRatio="xMidYMid meet" clip-path="url(#avatarClip)" />
					</svg>
				</div>
				<!-- 视觉：双弧静态文字——上弧站内导航（可点击），下弧外链；无旋转。 -->
				<div class="avatar-arc">
					<svg class="avatar-text-svg" viewBox="0 0 200 200" width="100%" height="100%" aria-hidden="true">
						<defs>
							<path id="topArc" d="M 20, 100 A 80, 80 0 0, 1 180, 100" />
							<path id="bottomArc" d="M 20, 100 A 80, 80 0 0, 0 180, 100" />
						</defs>
						<text font-size="13" font-weight="600" letter-spacing="1.2px" text-anchor="middle">
							<textPath href="#topArc" startOffset="50%">
								<a href="/projects" class="svg-link">Projects</a>
								<tspan fill="#d1d5db" font-weight="400"> · </tspan>
								<a href="/insights" class="svg-link">Insights</a>
								<tspan fill="#d1d5db" font-weight="400"> · </tspan>
								<a href="/plog" class="svg-link">Plog</a>
							</textPath>
						</text>
						<text font-size="13" font-weight="500" letter-spacing="1.2px" text-anchor="middle">
							<textPath href="#bottomArc" startOffset="50%">
								<a href="https://github.com/chloeguan818ss" target="_blank" rel="noopener noreferrer" class="svg-link-external">GitHub</a>
								<tspan fill="#d1d5db" font-weight="400"> · </tspan>
								<a href="https://www.linkedin.com/in/chloe-guan-92289b355/" target="_blank" rel="noopener noreferrer" class="svg-link-external">LinkedIn</a>
								<tspan fill="#d1d5db" font-weight="400"> · </tspan>
								<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="svg-link-external">Resume</a>
							</textPath>
						</text>
					</svg>
				</div>
			</div>

			<h1 class="hero-name">{lastName}</h1>
		</div>

		<!-- 视觉：自我介绍区域，左对齐、静态全文显示。 -->
		<div id="bio-text" class="bio-text intro">
			<div class="bio-tagline">Hi, I'm {firstName}.</div>
			<p class="intro-text bio-long-paragraph">Aspiring Cognitive Science researcher and AI Strategist focused on building human-centered intelligent systems. I explore how AI shifts human cognitive landscapes to identify emerging market opportunities and next-generation pain points, leveraging Machine Learning to enhance user accessibility and streamline digital-physical workflows.</p>
		</div>
	</section>

	<style>
		/* 视觉：主区块占满整个视口高度，所有子元素垂直水平居中。
		 * 逻辑：min-height:100vh 确保至少撑满屏幕；overflow:hidden 避免旋转动画溢出产生水平滚动条。
		 * flex-direction:column 使 hero-row 和 intro 上下堆叠。 */
		.hero {
			min-height: 100vh;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 2rem 1rem;
		}

		/* 视觉：First Name、头像、Last Name 横向一排居中对齐。
		 * 逻辑：flex-direction:row 将子元素排成一行；gap 设置间距；items-center 垂直居中。 */
		.hero-row {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: center;
			gap: 2rem;
		}

		@media (max-width: 480px) {
			/* 视觉：极小屏幕下缩小间距，防止内容溢出。 */
			.hero-row {
				gap: 1rem;
			}
		}

		/* 视觉：大号粗体姓名，移动端 3rem、桌面端 5rem。 */
		.hero-name {
			font-size: 3rem;
			font-weight: 700;
			letter-spacing: -0.05em;
			margin: 0;
		}

		@media (min-width: 768px) {
			.hero-name {
				font-size: 5rem;
			}
		}

		/* 视觉：固定尺寸的方形区域，内嵌圆形头像与旋转环。
		 * 逻辑：position:relative 作为 absolute 子层的定位参照；inset:0 使子层铺满容器。 */
		.avatar-container {
			position: relative;
			width: 12rem;
			height: 12rem;
			flex-shrink: 0;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		@media (min-width: 768px) {
			.avatar-container {
				width: 16rem;
				height: 16rem;
			}
		}

		.avatar-svg,
		.avatar-arc {
			position: absolute;
			inset: 0;
		}

		.avatar-svg svg,
		.avatar-arc svg {
			width: 100%;
			height: 100%;
		}

		/* 视觉：双弧静态文字，无旋转；SVG 与容器对齐。 */
		.avatar-arc {
			z-index: 20;
		}

		.avatar-text-svg {
			position: absolute;
			inset: 0;
			overflow: visible;
		}

		/* SVG 弧上链接：使用 fill 控制颜色，hover 时过渡。 */
		.svg-link,
		.svg-link-external {
			cursor: pointer;
			transition: fill 0.2s ease, opacity 0.2s ease;
		}

		/* 上弧：站内导航，深色强调 */
		.svg-link {
			fill: #111827;
		}

		.svg-link:hover {
			fill:rgb(136, 167, 234);
		}

		/* 下弧：外链，次要强调 */
		.svg-link-external {
			fill: #6b7280;
		}

		.svg-link-external:hover {
			fill: #111827;
		}

		/* 视觉：自我介绍区域，左对齐、占满可用宽度；静态全文，无打字效果。 */
		.intro,
		.bio-text {
			margin-top: 3rem;
			width: 100%;
			text-align: left;
			padding: 0 1rem;
			align-self: stretch;
		}

		.bio-tagline {
			font-size: 1.5rem;
			font-weight: 600;
			color: #111827;
			margin: 0 0 0.75rem;
		}

		/* 视觉：自我介绍正文大小与行高，灰色以提高可读性。 */
		.intro-text,
		.bio-long-paragraph {
			font-size: 1.25rem;
			color: #4b5563;
			line-height: 1.6;
			margin: 0;
		}
	</style>

</Layout>
